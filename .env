# ====== LIVE CAOS — configuracao ======

# Seu @ do TikTok (sem o @)
TIKTOK_USERNAME=davillops

# Modo simulacao: true = gera eventos falsos (testar sem live no ar)
SIMULATION=true

# WebSocket do overlay (nao mude se nao precisar)
WS_HOST=localhost
WS_PORT=8765

# Ritmo da fila: segundos entre execucoes de comandos
MIN_INTERVAL_SECONDS=1.5

# Espera quando o GMod esta fora de foco antes de tentar de novo
RETRY_DELAY_SECONDS=2.0

# Meta de likes para o zumbi (igual ao configurado no Tikfinity)
LIKES_GOAL=5
# Titulo da janela do jogo (parcial, sem diferencia maiusculas)
GAME_WINDOW_TITLE=Garry's Mod


# Tecla que abre o console do GMod — usada SO se algum comando usar o
# modo "console". Com a ponte por arquivo (modo "file"), nao e usada.
CONSOLE_KEY=`


# Caminho COMPLETO da fila lida pelo addon Lua. DEVE apontar para
# garrysmod/data/live_caos/fila.txt dentro da sua instalacao do GMod.
# Ajuste se seu Steam estiver noutro drive/pasta. Use barras normais /.
QUEUE_FILE=C:/Program Files (x86)/Steam/steamapps/common/GarrysMod/garrysmod/data/live_caos/fila.txt


# Arquivos
COMMANDS_FILE=commands.json
LOG_DIR=logs

TIKTOK_API_KEY=euler_NDg5OWI5MmMwODg4OGIzZTZjOTFlZjYzOThkMjAwNDhiMjVmYzY1NGVjODQxYmMzNDkzOTZh

QUEUE_MAX_SIZE=20
QUEUE_MAX_AGE_SECONDS=30

# Espectador vira personagem ao ENTRAR na live (true liga, false desliga).
# Cuidado: em live movimentada entra MUITA gente. Ligue so quando quiser.
JOIN_ENABLED=false

# Ranking/gamificacao: true liga o placar (live + historico em SQLite).
RANKING_ENABLED=true

# Arquivo do banco de dados do ranking (historico de sempre).
RANKING_DB=live_caos.db